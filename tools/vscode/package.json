{
  "name": "veda-language",
  "displayName": "Veda Language",
  "description": "Syntax highlighting, snippets, and icons for Veda (.veda).",
  "version": "0.0.1",
  "publisher": "veda",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "icon": "icons/veda-extension.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahansardar/Veda.git"
  },
  "contributes": {
    "languages": [
      {
        "id": "veda",
        "aliases": ["Veda", "veda"],
        "extensions": [".veda"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "veda",
        "scopeName": "source.veda",
        "path": "./syntaxes/veda.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "veda",
        "path": "./snippets/veda.json"
      }
    ],
    "iconThemes": [
      {
        "id": "veda-icons",
        "label": "Veda Icons",
        "path": "./themes/veda-icon-theme.json"
      }
    ]
  }
}
